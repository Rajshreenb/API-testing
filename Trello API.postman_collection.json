    {
      "name": "Create TO DO list",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status code os response is 200\",()=>{\r",
              "    pm.response.to.have.status(200);\r",
              "})\r",
              "const response= pm.response.json();\r",
              "pm.collectionVariables.set(\"CreateToDOlist\",response.id );\r",
              "pm.test(\"Name is TODO\",()=>{\r",
              "    pm.expect(response.name).to.eql(\"To do list\");\r",
              "})\r",
              "pm.test(\"List is open\",()=>{\r",
              "    pm.expect(response.closed).to.be.false;\r",
              "})\r",
              "pm.test(\"List is created in correct board\",()=>{\r",
              "    pm.expect(response.idBoard).to.eql(\"6a4888e4201af36c1678c153\");\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
